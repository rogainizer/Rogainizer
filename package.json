{
  "name": "rogainizer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:prod-db": "powershell -ExecutionPolicy Bypass -File ./deploy/start-local-with-prod-db.ps1",
    "dev:api": "npm run dev --prefix backend",
    "dev:web": "npm run dev --prefix frontend",
    "dev:web:remote-api": "npm run dev:remote-api --prefix frontend",
    "db:init": "npm run db:init --prefix backend",
    "docker:web:deps": "docker compose run --rm web npm install",
    "docker:start": "docker compose up --build",
    "docker:stop": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
